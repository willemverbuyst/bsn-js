{
  "name": "bsn-js",
  "version": "1.1.0",
  "description": "Generator/validator for (Dutch) BSNs",
  "keywords": [
    "BSN",
    "Burger Service Nummer",
    "Dutch",
    "generate",
    "validate"
  ],
  "license": "MIT",
  "author": "Willem Verbuyst",
  "repository": "https://github.com/willemverbuyst/bsn-js",
  "files": [
    "lib/**/*"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "knip:check": "knip",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "size:check": "size-limit",
    "test:unit": "vitest run",
    "type:check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf ./lib",
    "prepare": "husky",
    "prepublishOnly": "npm run test:unit && npm run lint:check",
    "preversion": "npm run lint:check",
    "version": "npm run fmt:check && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "semantic-release": "^25.0.3",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "size-limit": [
    {
      "path": "./lib/index.js"
    }
  ],
  "publishConfig": {
    "access": "public"
  }
}
